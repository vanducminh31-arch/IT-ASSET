rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return request.auth != null && getUserRole() == 'admin';
    }

    function isManager() {
      return request.auth != null && getUserRole() in ['admin', 'manager'];
    }

    // Users collection: anyone authenticated can read own doc, admin can read/write all
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if isAdmin();
    }

    // Transactions: manager+ can write, authenticated can read
    match /transactions/{txId} {
      allow read: if true;
      allow create, update: if isManager();
      allow delete: if isAdmin();
    }

    // Stock: manager+ can read/write
    match /stock/{stockId} {
      allow read: if isManager();
      allow create, update: if isManager();
      allow delete: if isAdmin();
    }

    // Stores, Offices, Warehouses: manager+ can read/write
    match /stores/{docId} {
      allow read: if isManager();
      allow write: if isManager();
    }
    match /offices/{docId} {
      allow read: if isManager();
      allow write: if isManager();
    }
    match /warehouses/{docId} {
      allow read: if isManager();
      allow write: if isManager();
    }
    match /minipc/{docId} {
      allow read: if isManager();
      allow write: if isManager();
    }
  }
}


